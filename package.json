    "circuit:verifier": "bash scripts/generate-verifier.sh",
    "setup:local": "bash scripts/local-setup.sh",
    "check:sizes": "npx hardhat compile && npx ts-node scripts/check-sizes.ts"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@openzeppelin/contracts": "^5.6.1",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "ffjavascript": "^0.3.1",
    "hardhat": "^2.22.0",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
